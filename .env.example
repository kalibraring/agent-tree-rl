# Local POSIX source-checkout example. Load it from the repository root with:
#   set -a; . ./.env.example; set +a
AGENT_TREE_RL_HOST=127.0.0.1
AGENT_TREE_RL_PORT=8080
AGENT_TREE_RL_DATA_DIR=${PWD}/var
AGENT_TREE_RL_RECEIPT_KEYS_FILE=${PWD}/var/receipt-keys.json
AGENT_TREE_RL_ADMIN_TOKEN_FILE=${PWD}/var/api-tokens.json
AGENT_TREE_RL_BACKUP_KEYS_FILE=${PWD}/var/backup-keys.json
AGENT_TREE_RL_BENCHMARK_DIR=${PWD}/var/benchmarks
AGENT_TREE_RL_BENCHMARK_FILE=${PWD}/var/benchmarks/policy.json
AGENT_TREE_RL_BENCHMARK_SIGNING_KEY_FILE=${PWD}/var/benchmark-signing.key
AGENT_TREE_RL_DATABASE=${PWD}/var/agent-tree-rl.sqlite3
AGENT_TREE_RL_REQUIRE_AUTH=true
AGENT_TREE_RL_ALLOWED_COMMANDS=${PWD}/agent_tree_rl/workers/evidence_probe.py
AGENT_TREE_RL_ALLOWED_CWD_ROOTS=${PWD}/var
AGENT_TREE_RL_MAX_WORKERS=8
AGENT_TREE_RL_MAX_OPERATIONAL_WORKERS=2
AGENT_TREE_RL_SHUTDOWN_GRACE_SECONDS=30
AGENT_TREE_RL_SHUTDOWN_CANCEL_SECONDS=5
AGENT_TREE_RL_DEFAULT_TENANT_BUDGET=10000
AGENT_TREE_RL_BENCHMARK_RECEIPT_MAX_AGE_SECONDS=300
AGENT_TREE_RL_MINIMUM_HIDDEN_BENCHMARK_SCORE_PPM=900000
AGENT_TREE_RL_HIDDEN_BENCHMARK_ATTEMPT_LIMIT=3
AGENT_TREE_RL_HIDDEN_BENCHMARK_QUOTA_WINDOW_SECONDS=300
AGENT_TREE_RL_REQUIRE_SEPARATION_OF_DUTIES=true
AGENT_TREE_RL_ALLOW_SAMPLE_BENCHMARK=true
AGENT_TREE_RL_LOG_FORMAT=json
AGENT_TREE_RL_LOG_LEVEL=INFO
