{
	admin off
	auto_https off
}

:8080 {
	encode zstd gzip

	request_body {
		max_size 10MB
	}

	header {
		-Server
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cache-Control "no-store"
	}

	# These endpoints are for the scheduler and monitoring network, not the
	# public route. Scrape the application directly on the backend network.
	@private path /metrics /readyz
	respond @private 404

	reverse_proxy {$UPSTREAM:agent-tree-rl:8081} {
		health_uri /readyz
		health_interval 10s
		health_timeout 2s
		fail_duration 30s
		lb_try_duration 2s
		transport http {
			dial_timeout 3s
			response_header_timeout 30s
			keepalive 30s
		}
	}
}
